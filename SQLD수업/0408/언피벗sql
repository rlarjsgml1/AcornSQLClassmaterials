CREATE TABLE score2 (
    student_id NUMBER,
    kor NUMBER,
    eng NUMBER,
    math NUMBER
);

INSERT INTO score2 VALUES (1, 90, 80, NULL);
INSERT INTO score2 VALUES (2, 70, NULL, 60);
COMMIT;


select * from score2;

-- EXCLUDE nulls 이 옵션은 unpivot에만 있다

SELECT *
FROM score2
--  EXCLUDE nulls 가 기본값 : null포함하지 않는다
UNPIVOT  EXCLUDE nulls(
    score FOR subject IN (kor, eng, math)
);

SELECT *
FROM score2
UNPIVOT INCLUDE NULLS (
    score FOR subject IN (kor, eng, math)
);